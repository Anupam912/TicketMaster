# Server Configuration
PORT=8080
GIN_MODE=release
HTTP_READ_TIMEOUT_SEC=10
HTTP_WRITE_TIMEOUT_SEC=15
HTTP_IDLE_TIMEOUT_SEC=60
HTTP_SHUTDOWN_TIMEOUT_SEC=10

# Database Configuration
# Railway Postgres can provide DATABASE_URL. If set, it takes precedence over DB_*.
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=event_ticketing
DB_SSLMODE=disable

# Redis Configuration
# Railway Redis can provide REDIS_URL. If set, it takes precedence over REDIS_*.
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Kafka Configuration (optional; leave KAFKA_BROKERS and KAFKA_URL empty to disable)
# Railway Kafka templates commonly expose KAFKA_URL for private-network access.
KAFKA_BROKERS=
KAFKA_URL=
KAFKA_PRIVATE_URL=
KAFKA_PUBLIC_URL=
KAFKA_BROKER_URL=
KAFKA_BOOKING_EVENTS_TOPIC=booking-events
KAFKA_BOOKING_EVENTS_DLQ_TOPIC=booking-events-dlq
KAFKA_BOOKING_COMMANDS_TOPIC=booking-commands
KAFKA_PURCHASE_COMMANDS_TOPIC=purchase-commands
KAFKA_BOOKING_DLQ_TOPIC=booking-commands-dlq
KAFKA_PURCHASE_DLQ_TOPIC=purchase-commands-dlq
KAFKA_CLIENT_ID=ticketmaster-api
KAFKA_REQUIRED_ACKS=leader
KAFKA_ASYNC=true
KAFKA_TOPIC_PARTITIONS=6
KAFKA_TOPIC_REPLICATION_FACTOR=1

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRY_HOURS=24

# Booking Configuration
RESERVATION_TIMEOUT_MINUTES=10
BOOKING_ADMISSION_WINDOW_SEC=60
BOOKING_ADMISSION_EVENT_LIMIT=5000
BOOKING_ADMISSION_CLIENT_LIMIT=10

# Queue Reliability Configuration
QUEUE_MAX_RETRIES=3
QUEUE_MONITOR_INTERVAL_SEC=15
QUEUE_ALERT_BOOKING_QUEUE_LENGTH=5000
QUEUE_ALERT_PURCHASE_QUEUE_LENGTH=5000
QUEUE_ALERT_BOOKING_PENDING=1000
QUEUE_ALERT_PURCHASE_PENDING=1000
QUEUE_ALERT_BOOKING_DLQ=10
QUEUE_ALERT_PURCHASE_DLQ=10

# Database Read Replica (Optional - for scaling reads)
# Leave empty to use primary database for all operations
DB_READ_HOST=
DB_READ_PORT=
DB_READ_USER=
DB_READ_PASSWORD=

# WebSocket Configuration
# Comma-separated list of allowed origins for WebSocket connections
# Leave empty to allow all origins (not recommended for production)
# Example: http://localhost:3000,https://myapp.com
WEBSOCKET_ALLOWED_ORIGINS=

# Stripe Payment Configuration
# Get your API keys from https://dashboard.stripe.com/apikeys
# Leave empty to use simulated payments (for development/testing)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_URL=http://localhost:8080/api/webhooks/stripe
STRIPE_CURRENCY=usd
